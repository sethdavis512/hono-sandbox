# Database (Railway provides this automatically for Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/hono_sandbox"

# Better Auth
BETTER_AUTH_SECRET="generate-a-random-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# Polar (https://polar.sh)
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""
POLAR_PRODUCT_ID=""
POLAR_SERVER="sandbox"  # "sandbox" for dev, "production" for live

# Port (Railway sets this automatically)
PORT=3000
